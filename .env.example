# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3001

# Database (required in production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/quicktools

# Auth (JWT_SECRET required in production — no fallback)
JWT_SECRET=replace_with_long_random_string

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AI
GEMINI_API_KEYS=

# Cron protection
CRON_SECRET=

# Email (optional)
EMAIL_USER=
EMAIL_PASS=
